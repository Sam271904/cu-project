# Copy to .env locally if needed (optional — backend defaults work for dev)

# SQLite path (prefix stripped by backend)
DATABASE_URL=sqlite:./data/app.db

# HTTP port (see also e2e Playwright on 3456)
PORT=3001

# Task 6.2: use mock-tagged decision summaries (or set forceMockOverlay in code/tests only)
# PIH_SIGNAL_EXTRACTOR=mock

# Task 6.2: force truth policy C for all clusters (optional). Valid: LATEST_WINS | EVIDENCE_WEIGHTED | SOURCE_TRUSTED | USER_OVERRIDE
# PIH_CHANGE_POLICY=LATEST_WINS

# Web Push pipeline (deferred product UI; backend tests may enable)
# PIH_PUSH_ENABLED=true
# PUSH_VAPID_CONTACT=mailto:you@example.com
# PUSH_VAPID_PRIVATE_KEY=

# Optional future LLM extraction
# LLM_PROVIDER=
# LLM_MODEL=

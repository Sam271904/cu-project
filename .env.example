# Copy to .env locally if needed (optional — backend defaults work for dev)

# SQLite path (prefix stripped by backend)
DATABASE_URL=sqlite:./data/app.db

# HTTP port (see also e2e Playwright on 3456)
PORT=3001

# Task 6.2: use mock-tagged decision summaries (or set forceMockOverlay in code/tests only)
# PIH_SIGNAL_EXTRACTOR=mock

# Task 6.2: force truth policy C for all clusters (optional). Valid: LATEST_WINS | EVIDENCE_WEIGHTED | SOURCE_TRUSTED | USER_OVERRIDE
# PIH_CHANGE_POLICY=LATEST_WINS

# Task 2.2: optional auth for POST /api/push/subscribe|unsubscribe|enqueue-test|send (Bearer or X-PIH-Token)
# PIH_PUSH_API_TOKEN=
# Task 8.1: optional at-rest encryption for notification_subscriptions.subscription_json
# PIH_PUSH_SUBSCRIPTION_SECRET=

# Web Push pipeline (deferred product UI; backend tests may enable)
# PIH_PUSH_ENABLED=true
# PUSH_VAPID_CONTACT=mailto:you@example.com
# PUSH_VAPID_PRIVATE_KEY=

# Optional: OpenAI-compatible summaries for decision signals (placeholder evidence_links unchanged)
# PIH_SIGNAL_EXTRACTOR=openai_compatible
# PIH_LLM_API_KEY=sk-...   # or OPENAI_API_KEY
# PIH_LLM_BASE_URL=https://api.openai.com/v1
# PIH_LLM_MODEL=gpt-4o-mini
# PIH_LLM_JSON_OBJECT=1   # set 0 if your gateway rejects response_format json_object

# Task 8.2: reminder scoring weights (design: score = w1*novelty + w2*conclusion_delta + w3*conflict_delta; sum auto-normalized)
# PIH_REMINDER_W1=0.4
# PIH_REMINDER_W2=0.4
# PIH_REMINDER_W3=0.2
# PIH_REMINDER_HIGH_THRESHOLD=0.8    # score >= => reminder_level high
# PIH_REMINDER_MEDIUM_THRESHOLD=0.5  # score >= => medium (below high)

# Design: claim_text embedding for conclusion_delta = 1 - cos_sim (needs API key)
# PIH_CLAIM_EMBEDDING=1
# PIH_EMBEDDING_MODEL=text-embedding-3-small
